#!/usr/bin/env bash
# Hard-blocks test-writer from:
#   Read  — internal/**, cmd/**, pkg/bus/memory.go
#   Write/Edit — anything outside evaluations/
#   Bash  — anything other than go test/build/vet
# Receives hook input JSON on stdin.

INPUT=$(cat)
TOOL=$(echo "$INPUT" | jq -r '.tool_name // empty')
FILE_PATH=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty')
COMMAND=$(echo "$INPUT" | jq -r '.tool_input.command // empty')

case "$TOOL" in
  Read)
    if [[ "$FILE_PATH" =~ /internal/ || "$FILE_PATH" =~ /cmd/ || "$FILE_PATH" =~ /bus/memory\.go$ ]]; then
      echo "Blocked: test-writer may not read $FILE_PATH" >&2
      exit 2
    fi
    ;;
  Write|Edit)
    if [[ ! "$FILE_PATH" =~ /evaluations/ ]]; then
      echo "Blocked: test-writer may only write under evaluations/. Got: $FILE_PATH" >&2
      exit 2
    fi
    ;;
  Bash)
    if [[ -n "$COMMAND" && ! "$COMMAND" =~ ^go[[:space:]]+(test|build|vet) ]]; then
      echo "Blocked: test-writer may only run go test/build/vet. Got: $COMMAND" >&2
      exit 2
    fi
    ;;
esac

exit 0
