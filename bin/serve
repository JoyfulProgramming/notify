#!/usr/bin/env bash
# Runs the whole Notify pipeline in one process: ingestor (:8080), rule-api
# (:8081), delivery-service + web UI (:8082). No Docker, no Pub/Sub emulator
# — everything is wired to an in-memory bus (see pkg/bus).
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

URL="http://localhost:8082/?token=local-key"

if command -v open >/dev/null 2>&1; then
  ( sleep 1 && open "$URL" ) &
fi

echo "Starting notify-local — ingestor :8080, rule-api :8081, deliver+web :8082"
echo "Web UI: $URL"
exec go run ./cmd/notify-local
